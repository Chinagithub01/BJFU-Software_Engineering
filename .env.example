# 复制为 .env 后按需修改
POSTGRES_PASSWORD=PeerReview@2026
APP_PORT=8080
JWT_SECRET=PeerReview-JWT-Secret-32Bytes!!

# 附件存储：minio（默认）| local（本地 uploads 卷）
STORAGE_BACKEND=minio
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=peerreview-uploads

# MinIO 镜像（默认已在 compose 中配置 DaoCloud，一般无需改）
# MINIO_IMAGE=m.daocloud.io/docker.io/minio/minio:latest
# MINIO_MC_IMAGE=m.daocloud.io/docker.io/minio/mc:latest

# PostgreSQL 拉取报 TLS 时可改用：
# POSTGRES_IMAGE=docker.m.daocloud.io/library/postgres:16-alpine

# 回退本地卷存储：
# STORAGE_BACKEND=local
